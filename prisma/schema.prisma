// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Product {
  id              String          @id @default(cuid())
  kfaCode         String?         @unique
  name            String
  brandName       String?
  genericName     String?
  category        String          // Store category values here (NARKOTIKA, PSIKOTROPIKA, etc.)
  form            String?         // Tablet, Syrup, etc.
  strength        String?         // 500mg, etc.
  unit            String?         // Box, Strip, Pcs
  stock           Int             @default(0)
  minStock        Int             @default(10)
  price           Float
  expiryDate      DateTime?
  batchNumber     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  movements       StockMovement[]
  transactionItems TransactionItem[]
}

model Patient {
  id        String   @id @default(cuid())
  nik       String   @unique
  name      String
  phone     String?
  address   String?
  birthDate DateTime?
  gender    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactions Transaction[]
}

model Transaction {
  id            String            @id @default(cuid())
  invoiceNumber String            @unique
  patientId     String?
  patient       Patient?          @relation(fields: [patientId], references: [id])
  doctorName    String?
  doctorSip     String?
  totalAmount   Float
  paymentMethod String            // QRIS, CASH, TRANSFER
  status        String            // PENDING, COMPLETED, CANCELLED
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         TransactionItem[]
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
  price         Float
  subtotal      Float
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // IN, OUT, ADJUSTMENT
  quantity    Int
  reason      String?  // PURCHASE, SALE, EXPIRED, RETURN
  referenceId String?  // TransactionId or PurchaseOrderId
  createdAt   DateTime @default(now())
}

model Configuration {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
}

